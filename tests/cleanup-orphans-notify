#!/bin/bash
orphans=$(pacman -Qtdq 2>/dev/null)
if [[ -z "$orphans" ]]; then exit 0; fi
count=$(echo "$orphans" | wc -l)
if command -v notify-send >/dev/null 2>&1; then
    notify-send -i edit-delete "Orphaned Packages" "$count orphaned package(s) found. Run cleanup-orphans to remove them." 2>/dev/null
fi
